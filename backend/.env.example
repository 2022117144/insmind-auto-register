# ==============================================================
# insMind Auto Register - 环境配置示例
# 复制此文件为 .env 并根据实际环境修改
# ==============================================================

# ============ 应用配置 ============
APP_NAME="insMind Auto Register"
DEBUG=false

# ============ 数据库配置 ============
# 默认使用 SQLite
DATABASE_URL="sqlite+aiosqlite:///./data/dreamina.db"

# ============ insMind 配置 ============
INSMIND_URL=https://www.insmind.com
INSMIND_REGISTER_TIMEOUT=300
INSMIND_VERIFICATION_TIMEOUT=180
INSMIND_CONCURRENCY=5

# ============ 代理 / Clash 配置 ============
CLASH_CONTROLLER_URL=http://127.0.0.1:9097
CLASH_SECRET=your_clash_secret_here

# 本地代理池配置 (可选)
CLASH_CONFIG_PATH=C:/Users/YourUser/AppData/Roaming/io.github.clash-verge-rev.clash-verge-rev/clash-verge.yaml
MIHOMO_BINARY_PATH=C:/Program Files/Clash Verge/verge-mihomo.exe

PROXY_POOL_START_PORT=21000
PROXY_POOL_CONTROLLER_PORT=9108
PROXY_POOL_SIZE=10
PROXY_POOL_KEYWORDS=HK,JP

# Clash 代理组配置
CLASH_PROXY_PORT=7897
CLASH_PROXY_GROUP=你的代理组名称

# ============ 外部代理配置 (可选) ============
EXT_PROXY_FILE_PATH=E:/your_proxies.txt

# ============ 其他任务配置 ============
MAX_RETRY_COUNT=2
MAX_CONCURRENCY=5
REGISTER_INTERVAL_MIN=10
REGISTER_INTERVAL_MAX=30
BROWSER_HEADLESS=false

# ============ Outlook Manager 配置 (可选) ============
OUTLOOK_MANAGER_URL=http://127.0.0.1:8089
OUTLOOK_MANAGER_API_KEY=your_outlook_manager_api_key
OUTLOOK_POLL_INTERVAL=5
OUTLOOK_POLL_TIMEOUT=120

# ============ 其他 API 配置 ============
# IP 信息接口 Token (ipinfo.io)（可选）
IPINFO_TOKEN=
